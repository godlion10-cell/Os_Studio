{
  "manifest_version": 3,
  "name": "Os Studio AI Flow 4321",
  "version": "2.0.0",
  "description": "Os Studio 대시보드 → Imagen/Runway/Suno 자동 주입 통합 공장",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://labs.google/fx/*",
    "https://translate.googleapis.com/*",
    "https://raw.githubusercontent.com/*",
    "https://app.runwayml.com/*",
    "https://lumalabs.ai/*",
    "https://suno.com/*",
    "https://elevenlabs.io/*",
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
